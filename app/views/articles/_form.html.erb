<%= form_with(model: nil, url: articles_path, method: :post) do |form| %>
  <% if article.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:</h2>

      <ul>
        <% article.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= fields_for @article do |f| %>
    <div>
      <%= f.label :title, style: "display: block" %>
      <%= f.text_field :title %>
    </div>

    <div>
      <%= f.label :body, style: "display: block" %>
      <%= f.text_area :body %>
    </div>
  <% end %>

  <%= fields_for @comment do |f| %>
    <div>
      <%= f.label :body, style: "display: block" %>
      <%= f.text_area :body %>
    </div>
  <% end %>

  <div>
    <%= form.submit %>
  </div>
<% end %>
